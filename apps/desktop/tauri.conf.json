{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axial",
  "version": "0.4.0-dev.2",
  "identifier": "dev.mateoltd.axial",
  "build": {
    "beforeBuildCommand": "cd ../../frontend && pnpm run build",
    "frontendDist": "../../frontend/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Axial",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "backgroundColor": "#100D0AFF"
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/macos/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
