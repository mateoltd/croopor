{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Croopor",
  "version": "0.3.1",
  "identifier": "dev.mateoltd.croopor",
  "build": {
    "beforeBuildCommand": "cd ../../frontend && pnpm run build",
    "beforeDevCommand": "cd ../../frontend && pnpm run dev:desktop",
    "frontendDist": "../../frontend/static",
    "devUrl": "http://127.0.0.1:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Croopor",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#100D0AFF"
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
