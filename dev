#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  cat <<'EOF'
croopor dev cli

setup once
  ./dev setup              install frontend deps and prefetch rust deps

daily
  ./dev dev                run desktop dev with rust + tauri
  ./dev dev-web            run the frontend-only dev server
  ./dev watch              rebuild frontend assets on file changes
  ./dev check              run static checks
  ./dev test               run rust tests
  ./dev verify             run checks, tests, and a release desktop build
  ./dev clean              remove build outputs and caches

build
  ./dev build              build the release desktop binary
  ./dev build-dev          build the dev desktop binary
  ./dev build:api          build the dev api binary
  ./dev build:api:release  build the release api binary

rust
  ./dev rust:check
  ./dev rust:clippy
  ./dev rust:fmt
  ./dev rust:fmt:fix
  ./dev rust:test
  ./dev rust:api
  ./dev rust:desktop

frontend
  ./dev frontend:install
  ./dev frontend:check
  ./dev frontend:build
  ./dev frontend:watch
  ./dev frontend:serve

other
  ./dev doctor
  ./dev help

notes
  - on WSL, desktop dev needs WSLg or another Linux GUI session
  - if you only need frontend work in WSL/headless, use ./dev dev-web
  - make is just a unix/wsl convenience wrapper around this script
  - Taskfile.yml mirrors these commands but is optional
EOF
}

check_desktop_env() {
  if [ -n "${WSL_DISTRO_NAME:-}" ] && [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
    echo "desktop dev needs WSLg or another Linux GUI session."
    echo "use './dev dev-web' for frontend-only work in headless WSL."
    exit 1
  fi
}

run_interruptible() {
  local interrupted=0
  trap 'interrupted=1' INT TERM
  set +e
  "$@"
  local status=$?
  set -e
  trap - INT TERM
  if [ "$interrupted" -eq 1 ] || [ "$status" -eq 130 ]; then
    exit 0
  fi
  exit "$status"
}

run_frontend() {
  corepack pnpm --dir "$ROOT/frontend" "$@"
}

run_setup() {
  run_frontend install --frozen-lockfile --ignore-scripts
  cargo fetch --locked
}

run_doctor() {
  echo "rustc    $(rustc --version)"
  echo "cargo    $(cargo --version)"
  echo "rustfmt  $(cargo fmt --version 2>/dev/null || echo missing)"
  echo "clippy   $(cargo clippy --version 2>/dev/null || echo missing)"
  echo "node     $(node --version)"
  echo "corepack $(corepack --version)"
  if command -v task >/dev/null 2>&1; then
    echo "task     $(task --version)"
  else
    echo "task     optional"
  fi
  if [ -n "${WSL_DISTRO_NAME:-}" ]; then
    echo "wsl      yes"
    if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
      echo "gui      detected"
    else
      echo "gui      missing, use './dev dev-web' or run under WSLg"
    fi
  else
    echo "wsl      no"
  fi
}

run_check() {
  run_frontend run check
  cargo fmt --all --check
  cargo check --workspace --locked
  cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
}

run_verify() {
  run_frontend run build
  run_check
  cargo test --workspace --locked
  cargo build --locked -p croopor-desktop --release
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    help|-h|--help)
      print_help
      ;;
    setup)
      run_setup
      ;;
    doctor)
      run_doctor
      ;;
    dev|dev:desktop|dev-desktop|rust:desktop)
      check_desktop_env
      run_interruptible cargo run --locked -p croopor-desktop
      ;;
    rust:api)
      run_interruptible cargo run --locked -p croopor-api
      ;;
    dev-web|frontend:serve|web)
      run_interruptible corepack pnpm --dir "$ROOT/frontend" run dev
      ;;
    watch|frontend:watch)
      run_interruptible corepack pnpm --dir "$ROOT/frontend" run watch
      ;;
    frontend:install)
      run_frontend install --frozen-lockfile --ignore-scripts
      ;;
    frontend:check)
      run_frontend run check
      ;;
    frontend:build)
      run_frontend run build
      ;;
    rust:fetch)
      cargo fetch --locked
      ;;
    rust:fmt)
      cargo fmt --all --check
      ;;
    rust:fmt:fix)
      cargo fmt --all
      ;;
    rust:check)
      cargo check --workspace --locked
      ;;
    rust:clippy)
      cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
      ;;
    rust:test|test)
      cargo test --workspace --locked
      ;;
    check)
      run_check
      ;;
    verify)
      run_verify
      ;;
    build|build-local)
      run_frontend run build
      cargo build --locked -p croopor-desktop --release
      ;;
    build-dev|build-local-dev)
      run_frontend run build
      cargo build --locked -p croopor-desktop
      ;;
    build:api)
      cargo build --locked -p croopor-api
      ;;
    build:api:release)
      cargo build --locked -p croopor-api --release
      ;;
    clean)
      cargo clean
      rm -rf "$ROOT/dist"
      ;;
    *)
      echo "unknown command: $cmd" >&2
      echo "run './dev help' to see available commands." >&2
      exit 1
      ;;
  esac
}

main "$@"
