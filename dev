#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  cat <<'EOF'
croopor dev cli

setup once
  ./dev setup              install frontend deps, prefetch rust deps, and prep Windows cross-builds on Linux/WSL

daily
  ./dev dev                run desktop dev with rust + tauri
  ./dev dev --target windows
  ./dev dev:windows        run desktop dev as a Windows app from linux/wsl
  ./dev dev-web            run the frontend-only dev server
  ./dev watch              rebuild frontend assets on file changes
  ./dev check              run static checks
  ./dev test               run rust tests
  ./dev verify             run checks, tests, and a release desktop build
  ./dev clean              remove build outputs and caches

build
  ./dev build              build the release desktop binary
  ./dev build-dev          build the dev desktop binary
  ./dev build --target windows
  ./dev build-dev --target windows
  ./dev build:windows      build the release Windows desktop binary from linux/wsl
  ./dev build:windows:dev  build the dev Windows desktop binary from linux/wsl
  ./dev build:api          build the dev api binary
  ./dev build:api:release  build the release api binary

rust
  ./dev rust:check
  ./dev rust:clippy
  ./dev rust:fmt
  ./dev rust:fmt:fix
  ./dev rust:test
  ./dev rust:api
  ./dev rust:desktop

frontend
  ./dev frontend:install
  ./dev frontend:check
  ./dev frontend:build
  ./dev frontend:watch
  ./dev frontend:serve

other
  ./dev doctor
  ./dev host:launch-evidence
  ./dev help

notes
  - on WSL, desktop dev needs WSLg or another Linux GUI session
  - host:launch-evidence reports Windows host Java and Minecraft/Croopor folders from WSL without printing paths
  - if you only need frontend work in WSL/headless, use ./dev dev-web
  - windows cross-builds use x86_64-pc-windows-gnu and require the rust target + mingw linker
  - make is just a unix/wsl convenience wrapper around this script
  - Taskfile.yml mirrors these commands but is optional
EOF
}

check_desktop_env() {
  if [ -n "${WSL_DISTRO_NAME:-}" ] && [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
    echo "desktop dev needs WSLg or another Linux GUI session."
    echo "use './dev dev-web' for frontend-only work in headless WSL."
    exit 1
  fi
}

run_interruptible() {
  local interrupted=0
  trap 'interrupted=1' INT TERM
  set +e
  "$@"
  local status=$?
  set -e
  trap - INT TERM
  if [ "$interrupted" -eq 1 ] || [ "$status" -eq 130 ]; then
    exit 0
  fi
  exit "$status"
}

run_frontend() {
  (
    cd "$ROOT/frontend"
    pnpm "$@"
  )
}

wait_for_frontend_dev_server() {
  local url="http://127.0.0.1:3000"
  local pid="${1:-}"

  for _ in $(seq 1 120); do
    if [ -n "$pid" ] && ! kill -0 "$pid" >/dev/null 2>&1; then
      echo "frontend dev server exited before $url became ready" >&2
      exit 1
    fi
    if command -v curl >/dev/null 2>&1 && curl -fsS --max-time 1 "$url" >/dev/null 2>&1; then
      return
    fi
    if ! command -v curl >/dev/null 2>&1 && node -e "fetch(process.argv[1]).then(() => process.exit(0)).catch(() => process.exit(1))" "$url" >/dev/null 2>&1; then
      return
    fi
    sleep 0.25
  done

  echo "frontend dev server did not become ready at $url" >&2
  exit 1
}

windows_target_triple() {
  echo "x86_64-pc-windows-gnu"
}

ensure_linux_windows_cross_setup() {
  local target
  target="$(windows_target_triple)"

  if rustup target list --installed | grep -Fxq "$target"; then
    :
  else
    rustup target add "$target"
  fi

  if ! command -v apt-get >/dev/null 2>&1; then
    return
  fi
  if command -v x86_64-w64-mingw32-gcc >/dev/null 2>&1; then
    return
  fi
  if [ "${CI:-}" = "true" ]; then
    echo "skipping apt install for Windows cross-build prerequisites in CI" >&2
    return
  fi

  if [ "$(id -u)" -eq 0 ]; then
    apt-get install -y gcc-mingw-w64-x86-64
    return
  fi
  if command -v sudo >/dev/null 2>&1; then
    sudo apt-get install -y gcc-mingw-w64-x86-64
    return
  fi

  echo "missing MinGW linker: x86_64-w64-mingw32-gcc" >&2
  echo "install it with: sudo apt-get install -y gcc-mingw-w64-x86-64" >&2
  exit 1
}

run_setup() {
  run_frontend install --frozen-lockfile --ignore-scripts
  cargo fetch --locked
  case "$(uname -s)" in
    Linux)
      ensure_linux_windows_cross_setup
      ;;
  esac
}

run_doctor() {
  echo "rustc    $(rustc --version)"
  echo "cargo    $(cargo --version)"
  echo "rustfmt  $(cargo fmt --version 2>/dev/null || echo missing)"
  echo "clippy   $(cargo clippy --version 2>/dev/null || echo missing)"
  echo "node     $(node --version)"
  echo "pnpm     $(pnpm --version)"
  if command -v task >/dev/null 2>&1; then
    echo "task     $(task --version)"
  else
    echo "task     optional"
  fi
  if [ -n "${WSL_DISTRO_NAME:-}" ]; then
    echo "wsl      yes"
    if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
      echo "gui      detected"
    else
      echo "gui      missing, use './dev dev-web' or run under WSLg"
    fi
  else
    echo "wsl      no"
  fi
}

is_wsl_host() {
  [ -n "${WSL_DISTRO_NAME:-}" ] || grep -qi microsoft /proc/version 2>/dev/null
}

run_host_launch_evidence() {
  if ! is_wsl_host; then
    echo "wsl no"
    echo "windows_host_evidence skipped"
    return 0
  fi

  echo "wsl yes"
  if ! command -v powershell.exe >/dev/null 2>&1; then
    echo "powershell no"
    echo "windows_host_evidence unavailable"
    return 0
  fi

  local ps_script
  ps_script="$(cat <<'POWERSHELL'
$ErrorActionPreference = 'SilentlyContinue'

function Emit {
  param([string]$Key, [object]$Value)
  if ($null -eq $Value -or [string]::IsNullOrWhiteSpace([string]$Value)) {
    $Value = 'unknown'
  }
  [Console]::Out.WriteLine(('{0} {1}' -f $Key, $Value))
}

function Child {
  param([string]$Base, [string]$Name)
  if ([string]::IsNullOrWhiteSpace($Base)) {
    return $null
  }
  return Join-Path $Base $Name
}

function LocationState {
  param([string]$Path)
  if ([string]::IsNullOrWhiteSpace($Path)) {
    return 'unknown'
  }
  if (Test-Path -LiteralPath $Path -PathType Container) {
    return 'present'
  }
  if (Test-Path -LiteralPath $Path -PathType Leaf) {
    return 'file'
  }
  return 'missing'
}

function DirectoryCount {
  param([string]$Path)
  if ([string]::IsNullOrWhiteSpace($Path) -or -not (Test-Path -LiteralPath $Path -PathType Container)) {
    return 0
  }
  $items = @(Get-ChildItem -LiteralPath $Path -Directory -Force -ErrorAction SilentlyContinue)
  return $items.Count
}

Emit 'powershell' 'yes'

$java = Get-Command java.exe -CommandType Application -ErrorAction SilentlyContinue | Select-Object -First 1
if ($java) {
  Emit 'windows_java_command' 'present'
  $oldErrorActionPreference = $ErrorActionPreference
  $ErrorActionPreference = 'Continue'
  $versionLine = (& java.exe -version 2>&1 | ForEach-Object { [string]$_ } | Select-Object -First 1)
  $ErrorActionPreference = $oldErrorActionPreference
  if ($versionLine -match '"([^"]+)"') {
    Emit 'windows_java_version' $Matches[1]
  } else {
    Emit 'windows_java_version' 'unknown'
  }
} else {
  Emit 'windows_java_command' 'missing'
  Emit 'windows_java_version' 'missing'
}

$minecraft = Child $env:APPDATA '.minecraft'
$minecraftRuntime = Child $minecraft 'runtime'
$minecraftVersions = Child $minecraft 'versions'
$minecraftLibraries = Child $minecraft 'libraries'
$minecraftAssets = Child $minecraft 'assets'
$storeRuntime = Child $env:LOCALAPPDATA 'Packages\Microsoft.4297127D64EC6_8wekyb3d8bbwe\LocalCache\Local\runtime'

$croopor = Child $env:APPDATA 'croopor'
$crooporInstances = Child $croopor 'instances'
$crooporLibrary = Child $croopor 'library'
$crooporRuntime = Child $crooporLibrary 'runtime'

Emit 'windows_appdata_minecraft' (LocationState $minecraft)
Emit 'windows_minecraft_versions' (LocationState $minecraftVersions)
Emit 'windows_minecraft_versions_count' (DirectoryCount $minecraftVersions)
Emit 'windows_minecraft_libraries' (LocationState $minecraftLibraries)
Emit 'windows_minecraft_assets' (LocationState $minecraftAssets)
Emit 'windows_minecraft_runtime' (LocationState $minecraftRuntime)
Emit 'windows_store_runtime' (LocationState $storeRuntime)

Emit 'windows_appdata_croopor' (LocationState $croopor)
Emit 'windows_croopor_instances' (LocationState $crooporInstances)
Emit 'windows_croopor_instances_count' (DirectoryCount $crooporInstances)
Emit 'windows_croopor_library' (LocationState $crooporLibrary)
Emit 'windows_croopor_runtime' (LocationState $crooporRuntime)
Emit 'windows_croopor_runtime_count' (DirectoryCount $crooporRuntime)
Emit 'windows_paths_redacted' 'yes'
POWERSHELL
)"

  powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command "$ps_script"
}

run_check() {
  run_frontend run check
  cargo fmt --all --check
  cargo check --workspace --locked
  cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
}

run_verify() {
  run_frontend run build
  run_check
  cargo test --workspace --locked
  cargo build --locked -p croopor-desktop --release
}

ensure_windows_cross_target_ready() {
  local target
  target="$(windows_target_triple)"

  if ! rustup target list --installed | grep -Fxq "$target"; then
    echo "missing Rust target: $target" >&2
    echo "install it with: rustup target add $target" >&2
    exit 1
  fi

  if ! command -v x86_64-w64-mingw32-gcc >/dev/null 2>&1; then
    echo "missing MinGW linker: x86_64-w64-mingw32-gcc" >&2
    echo "on Ubuntu/WSL install it with: sudo apt-get install -y gcc-mingw-w64-x86-64" >&2
    exit 1
  fi
}

resolve_build_target() {
  local target=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target)
        if [ "$#" -lt 2 ]; then
          echo "missing value for --target" >&2
          exit 1
        fi
        case "$2" in
          windows|windows-x64)
            target="$(windows_target_triple)"
            ;;
          *)
            target="$2"
            ;;
        esac
        shift 2
        ;;
      --windows|--windows-x64)
        target="$(windows_target_triple)"
        shift
        ;;
      *)
        echo "unknown build option: $1" >&2
        exit 1
        ;;
    esac
  done

  echo "$target"
}

report_desktop_artifact() {
  local profile="$1"
  local target="${2:-}"
  local artifact_root="$ROOT/target"
  local extension=""

  if [ -n "$target" ]; then
    artifact_root="$artifact_root/$target"
  fi
  if [[ "$target" == *windows* ]]; then
    extension=".exe"
  fi

  echo "artifact → $artifact_root/$profile/croopor-desktop$extension"
}

run_desktop_build() {
  local profile="$1"
  shift

  local target
  target="$(resolve_build_target "$@")"

  run_frontend run build

  if [ "$target" = "$(windows_target_triple)" ]; then
    ensure_windows_cross_target_ready
  fi

  local cargo_args=(build --locked -p croopor-desktop)
  if [ "$profile" = "release" ]; then
    cargo_args+=(--release)
  fi
  if [ -n "$target" ]; then
    cargo_args+=(--target "$target")
  fi

  cargo "${cargo_args[@]}"
  report_desktop_artifact "$profile" "$target"
}

run_desktop_dev() {
  local target
  target="$(resolve_build_target "$@")"

  if [ "$target" = "$(windows_target_triple)" ]; then
    ensure_windows_cross_target_ready
  else
    check_desktop_env
  fi

  local cargo_args=(run --locked -p croopor-desktop)
  if [ -n "$target" ]; then
    cargo_args+=(--target "$target")
  fi

  local frontend_pid=""
  cleanup_desktop_dev() {
    if [ -n "$frontend_pid" ] && kill -0 "$frontend_pid" >/dev/null 2>&1; then
      kill -- "-$frontend_pid" >/dev/null 2>&1 || kill "$frontend_pid" >/dev/null 2>&1 || true
      wait "$frontend_pid" >/dev/null 2>&1 || true
    fi
  }

  trap cleanup_desktop_dev EXIT
  if command -v setsid >/dev/null 2>&1; then
    setsid env PORT=3000 CROOPOR_WEB_API_BASE="${CROOPOR_WEB_API_BASE:-http://127.0.0.1:43430}" bash -lc 'cd "$1" && exec pnpm run dev:desktop' bash "$ROOT/frontend" &
  else
    env PORT=3000 CROOPOR_WEB_API_BASE="${CROOPOR_WEB_API_BASE:-http://127.0.0.1:43430}" bash -lc 'cd "$1" && exec pnpm run dev:desktop' bash "$ROOT/frontend" &
  fi
  frontend_pid=$!

  wait_for_frontend_dev_server "$frontend_pid"

  local interrupted=0
  trap 'interrupted=1; cleanup_desktop_dev' INT TERM
  set +e
  cargo "${cargo_args[@]}"
  local status=$?
  set -e
  trap - INT TERM
  cleanup_desktop_dev
  trap - EXIT

  if [ "$interrupted" -eq 1 ] || [ "$status" -eq 130 ]; then
    exit 0
  fi
  exit "$status"
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      print_help
      ;;
    setup)
      if [ "$#" -ne 0 ]; then
        echo "setup does not accept extra arguments" >&2
        exit 1
      fi
      run_setup
      ;;
    doctor)
      if [ "$#" -ne 0 ]; then
        echo "doctor does not accept extra arguments" >&2
        exit 1
      fi
      run_doctor
      ;;
    host:launch-evidence)
      if [ "$#" -ne 0 ]; then
        echo "host:launch-evidence does not accept extra arguments" >&2
        exit 1
      fi
      run_host_launch_evidence
      ;;
    dev|dev:desktop|dev-desktop|rust:desktop)
      run_desktop_dev "$@"
      ;;
    dev:windows|dev-windows)
      if [ "$#" -ne 0 ]; then
        echo "$cmd does not accept extra arguments" >&2
        exit 1
      fi
      run_desktop_dev --target windows
      ;;
    rust:api)
      if [ "$#" -ne 0 ]; then
        echo "rust:api does not accept extra arguments" >&2
        exit 1
      fi
      run_interruptible cargo run --locked -p croopor-api
      ;;
    dev-web|frontend:serve|web)
      if [ "$#" -ne 0 ]; then
        echo "$cmd does not accept extra arguments" >&2
        exit 1
      fi
      (
        export PORT="${PORT:-3000}"
        export CROOPOR_WEB_API_BASE="${CROOPOR_WEB_API_BASE:-http://127.0.0.1:43430}"
        run_interruptible run_frontend run dev:desktop
      )
      ;;
    watch|frontend:watch)
      if [ "$#" -ne 0 ]; then
        echo "$cmd does not accept extra arguments" >&2
        exit 1
      fi
      run_interruptible run_frontend run watch
      ;;
    frontend:install)
      if [ "$#" -ne 0 ]; then
        echo "frontend:install does not accept extra arguments" >&2
        exit 1
      fi
      run_frontend install --frozen-lockfile --ignore-scripts
      ;;
    frontend:check)
      if [ "$#" -ne 0 ]; then
        echo "frontend:check does not accept extra arguments" >&2
        exit 1
      fi
      run_frontend run check
      ;;
    frontend:build)
      if [ "$#" -ne 0 ]; then
        echo "frontend:build does not accept extra arguments" >&2
        exit 1
      fi
      run_frontend run build
      ;;
    rust:fetch)
      if [ "$#" -ne 0 ]; then
        echo "rust:fetch does not accept extra arguments" >&2
        exit 1
      fi
      cargo fetch --locked
      ;;
    rust:fmt)
      if [ "$#" -ne 0 ]; then
        echo "rust:fmt does not accept extra arguments" >&2
        exit 1
      fi
      cargo fmt --all --check
      ;;
    rust:fmt:fix)
      if [ "$#" -ne 0 ]; then
        echo "rust:fmt:fix does not accept extra arguments" >&2
        exit 1
      fi
      cargo fmt --all
      ;;
    rust:check)
      if [ "$#" -ne 0 ]; then
        echo "rust:check does not accept extra arguments" >&2
        exit 1
      fi
      cargo check --workspace --locked
      ;;
    rust:clippy)
      if [ "$#" -ne 0 ]; then
        echo "rust:clippy does not accept extra arguments" >&2
        exit 1
      fi
      cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
      ;;
    rust:test|test)
      if [ "$#" -ne 0 ]; then
        echo "$cmd does not accept extra arguments" >&2
        exit 1
      fi
      cargo test --workspace --locked
      ;;
    check)
      if [ "$#" -ne 0 ]; then
        echo "check does not accept extra arguments" >&2
        exit 1
      fi
      run_check
      ;;
    verify)
      if [ "$#" -ne 0 ]; then
        echo "verify does not accept extra arguments" >&2
        exit 1
      fi
      run_verify
      ;;
    build|build-local)
      run_desktop_build release "$@"
      ;;
    build-dev|build-local-dev)
      run_desktop_build debug "$@"
      ;;
    build:windows)
      if [ "$#" -ne 0 ]; then
        echo "build:windows does not accept extra arguments" >&2
        exit 1
      fi
      run_desktop_build release --target windows
      ;;
    build:windows:dev)
      if [ "$#" -ne 0 ]; then
        echo "build:windows:dev does not accept extra arguments" >&2
        exit 1
      fi
      run_desktop_build debug --target windows
      ;;
    build:api)
      if [ "$#" -ne 0 ]; then
        echo "build:api does not accept extra arguments" >&2
        exit 1
      fi
      run_frontend run build
      cargo build --locked -p croopor-api
      ;;
    build:api:release)
      if [ "$#" -ne 0 ]; then
        echo "build:api:release does not accept extra arguments" >&2
        exit 1
      fi
      run_frontend run build
      cargo build --locked -p croopor-api --release
      ;;
    clean)
      if [ "$#" -ne 0 ]; then
        echo "clean does not accept extra arguments" >&2
        exit 1
      fi
      cargo clean
      rm -rf "$ROOT/dist"
      ;;
    *)
      echo "unknown command: $cmd" >&2
      echo "run './dev help' to see available commands." >&2
      exit 1
      ;;
  esac
}

main "$@"
