#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$ROOT/.tools/bin"
TASK_BIN="$TOOLS_DIR/task"
TASK_VERSION="v3.49.1"

print_help() {
  cat <<'EOF'
croopor dev cli

setup once
  ./dev setup              install go deps, frontend deps, and local dev tools

daily
  ./dev dev                run desktop dev with wails
  ./dev dev-web            run the frontend-only dev server
  ./dev dev-windows        build and launch the windows dev binary
  ./dev build              build the native release binary for this machine
  ./dev build-dev          build the native dev binary for this machine
  ./dev verify             run checks, tests, and native builds
  ./dev clean              remove build outputs and go caches

other
  ./dev build-windows
  ./dev build-windows-dev
  ./dev release-snapshot
  ./dev doctor
  ./dev help

notes
  - on WSL, desktop dev needs WSLg or another Linux GUI session
  - if you only need frontend work in WSL/headless, use ./dev dev-web
  - if you want the windows app from WSL, use ./dev dev-windows
  - make is just a unix/wsl convenience wrapper around this script
EOF
}

ensure_task() {
  if [ -x "$TASK_BIN" ]; then
    return
  fi

  mkdir -p "$TOOLS_DIR"
  echo "bootstrapping local task into .tools/bin"
  GOBIN="$TOOLS_DIR" go install "github.com/go-task/task/v3/cmd/task@${TASK_VERSION}"
}

check_desktop_env() {
  if [ -n "${WSL_DISTRO_NAME:-}" ] && [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
    echo "desktop dev needs WSLg or another Linux GUI session."
    echo "use './dev dev-web' for frontend-only work in headless WSL."
    exit 1
  fi
}

is_interruptible_dev_command() {
  case "${1:-}" in
    dev|dev-web|watch|dev:desktop|dev-desktop|frontend:serve|frontend:watch|wails:dev)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

run_interruptible() {
  local interrupted=0
  trap 'interrupted=1' INT TERM
  set +e
  "$@"
  local status=$?
  set -e
  trap - INT TERM
  if [ "$interrupted" -eq 1 ] || [ "$status" -eq 130 ]; then
    exit 0
  fi
  exit "$status"
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    help|-h|--help)
      print_help
      exit 0
      ;;
    bootstrap)
      ensure_task
      exit 0
      ;;
  esac

  ensure_task
  export PATH="$TOOLS_DIR:$PATH"

  case "$cmd" in
    dev|dev:desktop|wails:dev)
      check_desktop_env
      ;;
  esac

  case "$cmd" in
    dev|dev:desktop|dev-desktop|wails:dev)
      export PATH="$TOOLS_DIR:$PATH"
      run_interruptible wails dev
      ;;
    dev-web|frontend:serve|web)
      cd "$ROOT/frontend"
      run_interruptible node esbuild.mjs serve
      ;;
    watch|frontend:watch)
      cd "$ROOT/frontend"
      run_interruptible node esbuild.mjs watch
      ;;
  esac

  exec "$TASK_BIN" -d "$ROOT" "$@"
}

main "$@"
