{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.13.1"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs serve",
    "dev:desktop": "node esbuild.mjs serve --strict-port",
    "dev:mock": "node esbuild.mjs serve --strict-port --mock",
    "watch": "node esbuild.mjs watch",
    "test": "node test/run.mjs",
    "verify": "pnpm run format:check && pnpm run test && pnpm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/three": "^0.184.1",
    "esbuild": "^0.25.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.2",
    "@preact/signals": "^2.0.0",
    "preact": "^10.25.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0"
  }
}
