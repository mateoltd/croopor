# Axial local environment example.
# Copy values into a local .env file or CI variables as needed.
# `task` loads .env and .env.local from the repo root for every command.

# Standalone API bind address. Defaults to 127.0.0.1:43430.
AXIAL_API_ADDR=127.0.0.1:43430

# Browser/dev frontend API base. The desktop shell injects its API base at runtime.
AXIAL_WEB_API_BASE=http://127.0.0.1:43430

# Optional desktop dev server port for `task dev`. Defaults to 1420.
DEV_PORT=1420

# Optional PostHog telemetry + remote feature flags (see docs/TELEMETRY.md).
# Leave unset to build with telemetry permanently disabled (keyless builds never upload).
# The key is a public write-only project token (phc_...). Host defaults to EU cloud.
# Environment defaults to "dev" in debug builds and "production" in release builds.
AXIAL_POSTHOG_API_KEY=
AXIAL_POSTHOG_HOST=https://eu.i.posthog.com
AXIAL_POSTHOG_ENVIRONMENT=

# Optional desktop Discord Rich Presence.
# Create a Discord Developer Portal application, copy its Application ID here,
# upload a Rich Presence large image asset with the key "axial",
# and upload small image assets with these keys:
# "axial_idle", "axial_launching", "axial_minecraft", "axial_multi".
# Leave unset to compile desktop builds without Discord RPC.
AXIAL_DISCORD_APPLICATION_ID=

# Optional static frontend directory for the API server.
# Leave unset to use frontend/static or the embedded frontend fallback.
AXIAL_FRONTEND_STATIC_DIR=

# Optional remote managed-performance rules.
# Leave unset to use bundled offline rules only.
AXIAL_PERFORMANCE_RULES_URL=
AXIAL_PERFORMANCE_RULES_ED25519_PUBLIC_KEY=
AXIAL_PERFORMANCE_RULES_REFRESH_INTERVAL_SECONDS=21600
