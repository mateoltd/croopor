# Croopor local environment example.
# Copy values into a local .env file or CI variables as needed.
# The ./dev script loads .env and .env.local from the repo root.

# Microsoft auth public client id.
# Use a dev app registration locally and a stable prod registration for releases.
CROOPOR_MSA_CLIENT_ID=

# Standalone API bind address. Defaults to 127.0.0.1:43430.
CROOPOR_API_ADDR=127.0.0.1:43430

# Browser/dev frontend API base. The desktop shell injects its API base at runtime.
CROOPOR_WEB_API_BASE=http://127.0.0.1:43430

# Optional frontend dev server port. Defaults to 3000.
PORT=3000

# Optional static frontend directory for the API server.
# Leave unset to use frontend/static or the embedded frontend fallback.
CROOPOR_FRONTEND_STATIC_DIR=

# Optional remote managed-performance rules.
# Leave unset to use bundled offline rules only.
CROOPOR_PERFORMANCE_RULES_URL=
CROOPOR_PERFORMANCE_RULES_ED25519_PUBLIC_KEY=
CROOPOR_PERFORMANCE_RULES_REFRESH_INTERVAL_SECONDS=21600
